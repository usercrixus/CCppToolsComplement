{
  "name": "ccpp-tools-complement",
  "displayName": "CCppToolsComplement",
  "description": "Generate JSON, Makefiles, VSCode integration, then launch debugging for C/C++ programs.",
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/usercrixus/CCppToolsComplement.git"
  },
  "homepage": "https://github.com/usercrixus/CCppToolsComplement",
  "bugs": {
    "url": "https://github.com/usercrixus/CCppToolsComplement/issues"
  },
  "license": "Apache-2.0",
  "keywords": [
    "c",
    "cpp",
    "c++",
    "makefile",
    "debug",
    "debugger",
    "cpptools",
    "vscode",
    "launch",
    "tasks"
  ],
  "version": "0.0.1",
  "publisher": "CHAISNEAU",
  "files": [
    "frontend/**",
    "package.json",
    "README.md",
    "LICENSE",
    "resources/**",
    "backend/**"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Debuggers",
    "Other"
  ],
  "extensionDependencies": [
    "ms-vscode.cpptools"
  ],
  "activationEvents": [
    "onCommand:ccppToolsComplement.generateAndDebugFromCurrentFile",
    "onLanguage:c",
    "onLanguage:cpp"
  ],
  "main": "./frontend/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ccppToolsComplement.generateAndDebugFromCurrentFile",
        "title": "CCppToolsComplement: Generate and Debug Current File",
        "icon": {
          "light": "resources/play-light.svg",
          "dark": "resources/play-dark.svg"
        }
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "ccppToolsComplement.generateAndDebugFromCurrentFile",
          "when": "resourceLangId == c || resourceLangId == cpp",
          "group": "navigation@1"
        }
      ],
      "commandPalette": [
        {
          "command": "ccppToolsComplement.generateAndDebugFromCurrentFile",
          "when": "resourceLangId == c || resourceLangId == cpp"
        }
      ]
    },
    "configuration": {
      "title": "CCppToolsComplement",
      "properties": {
        "ccppToolsComplement.pythonPath": {
          "type": "string",
          "default": "python3",
          "description": "Python executable used to run the generation scripts."
        }
      }
    }
  }
}
